<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/true_black"
    tools:context="dev.a2ys.conversa.main.fragments.StoriesFragment">

    <ImageView
        android:id="@+id/wait_illustration"
        android:layout_width="224dp"
        android:layout_height="224dp"
        android:src="@drawable/waiting"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="Data logs pending synchronization" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/zetra_blue"
        android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="@string/updates_section_is_coming_soon"
        android:fontFamily="@font/dm_sans"
        android:textSize="20sp"
        android:letterSpacing="0.05"
        android:textAlignment="center"/>

</androidx.constraintlayout.widget.ConstraintLayout>
