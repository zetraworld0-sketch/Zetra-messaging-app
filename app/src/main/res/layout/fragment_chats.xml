<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/true_black"
    tools:context="dev.a2ys.conversa.main.fragments.ChatsFragment">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp"/>

    <LinearLayout
        android:id="@+id/empty_state_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical">
        
        <ImageView
            android:id="@+id/search_illustration"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:src="@drawable/no_chats"
            android:layout_gravity="center"
            android:visibility="gone"
            android:contentDescription="No active nodes detected" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="32dp"
            android:text="@string/where_dem_chats_at"
            android:textColor="#475569"
            android:textAlignment="center"
            android:textSize="14sp"
            android:fontFamily="@font/dm_sans"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/extended_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:layout_gravity="bottom|end"
        android:text="@string/start_chat"
        android:textColor="@color/true_black"
        android:fontFamily="@font/dm_sans"
        android:textAllCaps="true"
        app:backgroundTint="@color/zetra_blue"
        app:icon="@drawable/logo_icon"
        app:iconTint="@color/true_black"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
