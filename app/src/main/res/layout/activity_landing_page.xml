<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="32dp">

    <LinearLayout
        android:id="@+id/brandHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/app_logo_hero"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/logo_icon"
            android:scaleType="fitCenter"
            android:contentDescription="Netscape Core Identity Logo" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Initializing Netscape Sovereign Hub"
            android:textColor="#8A99AD"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"
            android:layout_gravity="center_horizontal"/>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Netscape"
            android:textColor="#FFFFFF"
            android:textSize="46sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif-black"
            android:layout_gravity="center_horizontal"/>
    </LinearLayout>

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Connect to your secure communications profile using your international mobile telephone network identifier."
        android:textColor="#5C6F84"
        android:textSize="15sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.3"
        app:layout_constraintTop_toBottomOf="@id/brandHeader"
        app:layout_constraintBottom_toTopOf="@id/actionBlock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/actionBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/access_via_id_bridge"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Access via Phone Number"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#00A2FF"
            app:cornerRadius="12dp"/>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Made from Zetra Lab"
            android:textColor="#3D4D5F"
            android:textSize="12sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:letterSpacing="0.1"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
