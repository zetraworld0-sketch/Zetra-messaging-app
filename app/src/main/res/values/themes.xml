        <item name="colorSecondary">@color/zetra_blue</item>
        <item name="colorOnSecondary">@color/true_black</item>
        
        <item name="colorError">#FF5555</item>
        <item name="colorOnError">#FFFFFF</item>
        
        <item name="android:colorBackground">@color/true_black</item>
        <item name="colorOnBackground">#FFFFFF</item>
        <item name="colorSurface">@color/true_black</item>
