<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Conversa" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@color/true_black</item>
        <item name="android:navigationBarColor">@color/true_black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">true</item>

        <item name="colorPrimary">@color/zetra_blue</item>
        <item name="colorOnPrimary">@color/true_black</item>
        <item name="colorPrimaryContainer">@color/md_theme_dark_primaryContainer</item>
